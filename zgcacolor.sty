\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{zgcacolor}[2026/06/12 ZGCA Color Theme]

\RequirePackage{xcolor}

% Main Theme Color (中关村学院标准蓝色 #0363c9)
\definecolor{maincolor}{HTML}{0363C9}
\definecolor{zgcablue}{HTML}{0363C9}

% Light blue-grey background fill for blocks
\definecolor{zgcagrey}{HTML}{F0F4FA}
\colorlet{zgcagray}{zgcagrey}

% Accent colors that look great with #0363c9
\definecolor{zgcayellow}{HTML}{FFB800}    % Accent yellow (alerts)
\definecolor{zgcapink}{HTML}{E0115F}      % Accent pink
\definecolor{zgcateal}{HTML}{00A896}      % Accent teal
\definecolor{zgcalightteal}{HTML}{E6F7F5}  % Accent light teal for blocks

\colorlet{alertcolor}{zgcayellow}
