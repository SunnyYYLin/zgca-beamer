% Template for Zhongguancun Academy (ZGCA) presentations with LaTeX beamer.
%
% Adapted by Antigravity AI for ZGCA.
% Based on SINTEF Beamer theme.
% 

\ProvidesPackage{beamerthemezgca}[2026/06/12 ZGCA Beamer Theme]

\RequirePackage{etoolbox}
\RequirePackage{tikz}

% Force 16:9 aspect ratio
\RequirePackage{geometry}
\geometry{paperwidth=16cm,paperheight=9cm}

% Fonts
\RequirePackage{caladea,carlito}
\renewcommand{\familydefault}{\sfdefault}

\RequirePackage{graphicx,zgcacolor}

% Math, CJK, and font dependencies
\RequirePackage{amsfonts,amsmath,oldgerm}
\RequirePackage{xeCJK}
\usefonttheme[onlymath]{serif}

% Helper macros
\newcommand{\hrefcol}[2]{\textcolor{zgcayellow}{\href{#1}{#2}}}
\newcommand{\testcolor}[1]{\colorbox{#1}{\textcolor{#1}{test}}~\texttt{#1}}
% Helper macro to render the frame subtitle (always only section name inside sections)
\newcommand{\zgca@rendersubtitle}{%
  \ifnum\c@section>0 %
    \thesection \, \secname%
  \else%
    \insertframesubtitle%
  \fi%
}


% No navigation symbols
\setbeamertemplate{navigation symbols}{}

\newcommand{\@footlineauthor}{\insertauthor \enspace$\vert$\enspace}
\newcommand{\@footlinepayoff}{\@footlineauthor\inserttitle}
\newcommand{\footlinepayoff}[1]{\renewcommand{\@footlinepayoff}{#1}}

% Define footline content
\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\textwidth,ht=5mm,dp=3mm,rightskip=1cm,leftskip=1cm]{footline}
  \insertframenumber/\inserttotalframenumber
  \ifstrempty{\@footlinepayoff}{}{%
    \usebeamerfont{footline}\hfill\@footlinepayoff
  }
  \end{beamercolorbox}
}

% Set footline AND coordinate blocks with it
\newcommand{\footlinecolor}[1]{% if #1 is empty, makes footline transparent
  \ifstrempty{#1}{%
    \footlinepayoff{}
    \setbeamercolor{footline}{fg=darkgray, bg=}
    \setbeamercolor{block title}{fg=white,bg=maincolor}
    \setbeamercolor{block body}{fg=darkgray,bg=zgcagrey}
  }{
    \footlinepayoff{\@footlineauthor\inserttitle}
    \setbeamercolor{footline}{fg=white,bg=#1}
    \setbeamercolor{block title}{fg=white,bg=#1}
    \setbeamercolor{block body}{fg=white,bg=#1}
  }%
}
\footlinecolor{} % Default: no footline

% Declare ZGCA Logo images
\pgfdeclareimage[width=0.35\paperwidth]{logo}{assets/logo_RGB}
\pgfdeclareimage[width=0.35\paperwidth]{whitelogo}{assets/logo_RGB_negative}
\pgfdeclareimage[width=0.045\paperwidth]{logo_icon}{assets/logo_icon}
\pgfdeclareimage[width=0.045\paperwidth]{whitelogo_icon}{assets/logo_icon_negative}

\newcommand{\@logo}{logo}
\newcommand{\@logoicon}{logo_icon}

% Set colours and theme styles
\newcommand{\themecolor}[1]{
	\ifstrequal{#1}{main}{%
        \setbeamercolor{footline}{fg=white}
		\setbeamercolor{normal text}{fg=white,bg=maincolor}
		\setbeamercolor{structure}{fg=white}
		\renewcommand{\@logo}{whitelogo}
		\renewcommand{\@logoicon}{whitelogo_icon}
		\setbeamercolor{block title}{fg=maincolor,bg=zgcagrey}
		\setbeamercolor{block body}{fg=darkgray,bg=zgcagrey}
	}{%
        \setbeamercolor{footline}{fg=darkgray}
		\setbeamercolor{normal text}{fg=darkgray,bg=white}
		\setbeamercolor{structure}{fg=maincolor}
		\renewcommand{\@logo}{logo}
		\renewcommand{\@logoicon}{logo_icon}
		\setbeamercolor{block title}{fg=white,bg=maincolor}
		\setbeamercolor{block body}{fg=darkgray,bg=zgcagrey}
	}
}
\themecolor{white} % Default: white theme

\setbeamercolor{title}{fg=white,bg=}
\setbeamercolor{alerted text}{fg=zgcayellow}
\setbeamercolor{author}{fg=white}
\setbeamercolor{date}{fg=white}
\setbeamercolor{subtitle}{fg=white}

\setbeamerfont{author}{size=\small}
\setbeamerfont{date}{size=\small}
\setbeamerfont{title}{series=\bfseries,size=\Large}
\setbeamerfont{subtitle}{series=\mdseries,size=\small}
\setbeamerfont{frametitle}{series=\bfseries,size=\large}
\setbeamerfont{framesubtitle}{series=\mdseries,size=\small}
\setbeamerfont{footline}{size=\scriptsize}
\setbeamerfont{block title}{series=\centering\bfseries}

% Code to get prettier boxes
\setbeamertemplate{blocks}[rounded]

% Bullets in several levels
\setbeamertemplate{itemize item}{\textbullet}
\setbeamertemplate{itemize subitem}{\textemdash}
\setbeamertemplate{itemize subsubitem}{\ensuremath{\circ}}

\newenvironment{colorblock}[3][white]{%
	\begingroup
	\setbeamercolor{block title}{fg=#1,bg=#2}
	\setbeamercolor{block body} {fg=#1,bg=#2}
	\begin{block}{#3}
	}{%
	\end{block}
	\endgroup
}

% Put the logo in each slide's top area (headline)
\setbeamertemplate{headline}{%
  \vspace{0.8cm}%
  \begin{beamercolorbox}[wd=\paperwidth,ht=0.8cm,dp=0.2cm]{headline}
    \hfill%
    \pgfuseimage{\@logo}%
    \hspace*{0.02\paperwidth}%
  \end{beamercolorbox}%
}

\setbeamertemplate{frametitle}{%
  \vspace*{-4.5ex}% Pull it up to sit perfectly in line with the top right logo
  \begin{beamercolorbox}{frametitle}%
    \raisebox{-0.2\height}{\pgfuseimage{\@logoicon}}%
    \hspace{0.2cm}%
    \begin{minipage}[c][0.8cm][c]{0.55\paperwidth}%
      \usebeamerfont{frametitle}\insertframetitle\\
      \usebeamerfont{framesubtitle}\zgca@rendersubtitle
    \end{minipage}%
  \end{beamercolorbox}%
}

\def\@courseLabel{}
\def\@IDnumber{}

\newcommand{\course}[1]{\def\@courseLabel{#1}}
\newcommand{\IDnumber}[1]{\def\@IDnumber{#1}}

% Define the title page
\setbeamertemplate{title page}{%
  \vskip0pt plus 1filll%
  \hspace{-12mm}%
  \vspace{22mm}%
  \begin{beamercolorbox}[wd=0.85\textwidth,sep=10pt,leftskip=12mm]{title}%
    {\usebeamerfont{title}\inserttitle}\par
    \vspace{0.2cm}
    {\usebeamerfont{subtitle}\insertsubtitle}\par
    \ifdefempty{\@courseLabel}{}{\vspace{0.1cm}{\usebeamerfont{subtitle}\@courseLabel}\par}
    \vspace{0.4cm}
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\textbf{\insertauthor} \ifdefempty{\@IDnumber}{}{(\@IDnumber)}}\par
    \vspace{0.1cm}
    {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate}%
  \end{beamercolorbox}%
}

% Define slide splitting dimensions (e.g. title and chapter slides)
\newcommand{\TikzSplitSlide}[1]{%
  \rule{0.56\paperwidth}{0pt}%
  \begin{tikzpicture}
    \clip (-0.1\paperwidth,-0.5\paperheight) -- 
          ( 0.5\paperwidth,-0.5\paperheight) -- 
          ( 0.5\paperwidth, 0.5\paperheight) -- 
          ( 0.1\paperwidth, 0.5\paperheight) -- cycle; 
    \node at (0.2\paperwidth,0) {%
      \includegraphics[height=\paperheight]{#1}%
    };
  \end{tikzpicture}
}

\newbool{splittitle}
\newcommand{\@TitleBackground}{}
\newcommand{\titlebackground}{\@ifstar{\SplitBackground}{\FullBackground}}
\newcommand{\FullBackground}[1]{\renewcommand{\@TitleBackground}{#1}}
\newcommand{\SplitBackground}[1]{%
	\booltrue{splittitle}%
	\renewcommand{\@TitleBackground}{#1}%
}

% Overwrite the maketitle command for the title page
\renewcommand{\maketitle}{
\begingroup
  \ifdefempty{\@TitleBackground}{}{% Skip if \@TitleBackground is empty
    \setbeamertemplate{background}{%
      \ifbool{splittitle}{%
        \TikzSplitSlide{\@TitleBackground}
      }{% Normal, full-screen background
        \includegraphics[width=\paperwidth,height=\paperheight]{\@TitleBackground}
      }
    }
  }
  % On title page, we also put the white logo at the top left
  \setbeamertemplate{headline}{%
    \vspace{0.6cm}%
    \begin{beamercolorbox}[wd=\paperwidth,ht=0.8cm,dp=0.2cm]{headline}
      \hspace{0.05\paperwidth}%
      \pgfuseimage{whitelogo}% Logo banner at the top left of title page (matching PPT slide 1: LOGO-psd.psd at L=0.21 in, T=0.54 in, W=6.46 in)
      \hfill%
    \end{beamercolorbox}%
  }
  \setbeamertemplate{footline}{}
  \begin{frame}[noframenumbering]%
  \titlepage%
  \end{frame}%
\endgroup
}

\makeatletter
    \newenvironment{withoutheadline}{
        \setbeamertemplate{headline}[default]
        \def\beamer@entrycode{\vspace*{-\headheight}}
    }{}

% Define chapter environment
\newenvironment{chapter}[3][]{% Args: image (optional), color, frame title
  \begingroup
  \themecolor{main}
  \setbeamertemplate{footline}{}
  \ifstrempty{#2}{
    \setbeamercolor{frametitle}{fg=white}
    \setbeamercolor{normal text}{fg=white,bg=maincolor}
  }{
    \setbeamercolor{frametitle}{fg=white}
    \setbeamercolor{normal text}{fg=white,bg=#2}
  }
  \ifstrempty{#1}{}{\setbeamertemplate{background}{\TikzSplitSlide{#1}}}
  \setbeamertemplate{frametitle}{%
    \vspace*{4ex}
    \begin{beamercolorbox}[wd=0.45\textwidth]{frametitle}
      \usebeamerfont{frametitle}\insertframetitle\\
      \usebeamerfont{framesubtitle}\insertframesubtitle
    \end{beamercolorbox}
  }
  \begin{frame}[t,noframenumbering]{#3}
  \vspace*{-0.8ex}%
  \hspace*{0.05\textwidth}%
  \minipage{0.35\textwidth}%
  \usebeamercolor[fg]{normal text}%
}{%
  \endminipage
  \end{frame}
  \endgroup
}

% Define sidepic environment
\newenvironment{sidepic}[2]{% Args: image, frame title
  \begingroup
  \setbeamertemplate{background}{%
  \hspace*{0.6\paperwidth}%
  \includegraphics[height=\paperheight]{#1}%
  }
  \setbeamertemplate{frametitle}{% Same as normal, but with right skip and logo icon
    \vspace*{-4.5ex}% Pull it up to sit perfectly in line with the top right logo
    \begin{beamercolorbox}[rightskip=0.4\textwidth]{frametitle}%
      \raisebox{-0.2\height}{\pgfuseimage{\@logoicon}}%
      \hspace{0.2cm}%
      \begin{minipage}[c][0.8cm][c]{0.55\paperwidth}%
        \usebeamerfont{frametitle}\insertframetitle\\
        \usebeamerfont{framesubtitle}\zgca@rendersubtitle
      \end{minipage}%
    \end{beamercolorbox}%
  }
  \begin{frame}{#2}
  \minipage{0.6\textwidth}%
}{%
  \endminipage
  \end{frame}
  \endgroup
}

% Define backmatter
\newcommand{\backmatter}[1][]{
\begingroup
  \themecolor{main}
  \setbeamertemplate{background}{%
    \includegraphics[width=\paperwidth,height=\paperheight]{assets/background}
  }
  \setbeamertemplate{headline}{%
    \vspace{0.6cm}%
    \begin{beamercolorbox}[wd=\paperwidth,ht=0.8cm,dp=0.2cm]{headline}
      \hspace{0.05\paperwidth}%
      \pgfuseimage{whitelogo}%
      \hfill%
    \end{beamercolorbox}%
  }
  \begin{frame}[plain,c,noframenumbering]
    \centering
    \begin{minipage}{\textwidth}
      \usebeamercolor[fg]{normal text}
      \centering
      \ifstrequal{#1}{notitle}{}{
        \Huge \bfseries \inserttitle \par
        \vspace{8mm}
      }
      \Large \textsl{Thank you for listening! \\ Any questions?}
    \end{minipage}
  \end{frame}
\endgroup
}

% Define sectioning and table of contents
\AtBeginSection[]
{
    \begingroup
    \themecolor{main}
    \setbeamertemplate{background}{%
      \includegraphics[width=\paperwidth,height=\paperheight]{assets/background_negative}
    }
    \setbeamertemplate{headline}{}
    \begin{frame}[plain,noframenumbering]
        \centering
        \vspace{1cm}%
        \begin{minipage}{12cm}
            \setbeamercolor{block title}{fg=white, bg=maincolor}
            \setbeamercolor{block body}{fg=darkgray, bg=zgcagrey}
            \begin{block}{\large \bfseries 目录 \quad CONTENTS}
                \vspace{0.3cm}
                \usebeamercolor[fg]{normal text}
                \setbeamercolor{section in toc}{fg=maincolor}
                \setbeamercolor{section in toc shaded}{fg=gray}
                \setbeamercolor{structure}{fg=maincolor}
                \tableofcontents[currentsection]
                \vspace{0.3cm}
            \end{block}
        \end{minipage}
    \end{frame}
    \endgroup
}

% style of section presented in the table of contents
\setbeamertemplate{section in toc}{$\blacktriangleright$~\inserttocsection}

\makeatother

% avoid numbering of frames that are breaked into multiply slides
\setbeamertemplate{frametitle continuation}{}
